---
import Base from '../layouts/Base.astro';
import roomsData from '../data/rooms.json';
const base = import.meta.env.BASE_URL;
---
<Base title="Collection">
  <div class="wrap" style="padding-top:var(--s8);">
    <div style="margin-bottom:var(--s7);">
      <div class="sec-eye">The Mood Haus Collection</div>
      <h1 class="sec-title" style="font-size:clamp(36px,5vw,64px);">Interior Design<br>for Every Home</h1>
    </div>
    {roomsData.length === 0 && (
      <div style="text-align:center;padding:80px 0;color:var(--ink-3);font-family:var(--f-mono);font-size:12px;">No rooms published yet.</div>
    )}
    <div class="room-grid">
      {roomsData.map(room => (
        <a href={`${base}room/${room.queueId}/`} class="room-card">
          <div class="room-img">
            <img src={`${base}rooms/${room.queueId}.jpg`} alt={room.setName} loading="lazy" onerror="this.outerHTML='<div class=ph></div>'" />
            <div class="room-pl">{room.plateNum}</div>
          </div>
          <div class="room-title">{room.setName}</div>
          <div class="room-sub">{room.bgName}</div>
        </a>
      ))}
    </div>
  </div>
</Base>
