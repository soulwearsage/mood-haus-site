---
import Base from '../../layouts/Base.astro';
import roomsData from '../../data/rooms.json';

export async function getStaticPaths() {
  return roomsData.map(room => ({
    params: { id: room.queueId },
    props: { room },
  }));
}

const { room } = Astro.props;
const base = import.meta.env.BASE_URL;
const localImage = `${base}rooms/${room.queueId}.jpg`;
---
<Base title={room.plateNum + ' ' + room.setName} ogImage={localImage}>
  <style is:global>
    a{color:inherit;text-decoration:none;}
    .hero-cta{color:var(--ink) !important;text-decoration:none !important;border-bottom:1px solid var(--ink);}
    .shop-section{padding-block:var(--s8);}
    .shop-grid-room{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1px;background:var(--rule);}
    .shop-card-room{background:var(--paper);padding:var(--s4);}
    .shop-img-room{aspect-ratio:1/1;overflow:hidden;background:var(--rule-2);margin-bottom:var(--s3);display:flex;align-items:center;justify-content:center;}
    .shop-img-room img{width:100%;height:100%;object-fit:cover;}
    .shop-cat-room{font-family:var(--f-mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:3px;}
    .shop-name-room{font-size:13px;font-weight:500;margin-bottom:2px;line-height:1.3;}
    .shop-brand-room{font-family:var(--f-italic);font-style:italic;font-size:13px;color:var(--ink-2);margin-bottom:var(--s3);}
    .shop-btn-room{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--ink);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;transition:all .2s;color:var(--ink);}
    .shop-btn-room:hover{background:var(--ink);color:var(--white);}
    .shop-soon-room{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--rule);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
    .prompt-box{background:var(--ink);padding:var(--s6);margin-top:var(--s7);}
    .prompt-label{font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:var(--s3);display:block;}
    .prompt-text{font-family:var(--f-mono);font-size:11px;line-height:1.8;color:rgba(255,255,255,.7);white-space:pre-wrap;}
    .back-link{display:inline-block;margin-top:var(--s6);font-family:var(--f-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
    .back-link:hover{color:var(--blue);}
  </style>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-img">
      <img src={localImage} alt={room.setName} onerror="this.style.opacity='0'" />
      <div class="hero-plate">{room.plateNum} — {room.setName}</div>
    </div>
    <div class="hero-panel">
      <div>
        <div class="hero-eyebrow">Featured Room · {room.plateNum}</div>
        <h1 class="hero-title">{room.setName}</h1>
        <div class="hero-meta">
          <div class="hero-meta-block">
            <div>
              <div class="hero-meta-label">Layout</div>
              <div class="hero-meta-value">{room.layoutType}</div>
            </div>
            <div>
              <div class="hero-meta-label">Collection</div>
              <div class="hero-meta-value">{room.setName}</div>
            </div>
            <div>
              <div class="hero-meta-label">Rating</div>
              <div class="hero-meta-value">{room.rating}</div>
            </div>
          </div>
        </div>
      </div>
      <a class="hero-cta" href="#shop">
        Shop the Room
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <!-- SHOP THE ROOM -->
  <div class="wrap" id="shop">
    <div class="shop-section">
      <div class="sec-eye">Shop the Room</div>
      <div class="shop-grid-room">
        {room.furniture.filter(f => f.name).map(f => (
          <div class="shop-card-room">
            <div class="shop-img-room">
              {f.imageUrl
                ? <img src={f.imageUrl} alt={f.name} loading="lazy" />
                : <span style="font-size:28px;opacity:.2;">🪑</span>
              }
            </div>
            {f.category && <div class="shop-cat-room">{f.category}</div>}
            <div class="shop-name-room">{f.name}</div>
            {f.brand && <div class="shop-brand-room">{f.brand}</div>}
            {f.affiliateUrl
              ? <a href={f.affiliateUrl} target="_blank" rel="noopener noreferrer" class="shop-btn-room">Shop →</a>
              : <div class="shop-soon-room">Coming Soon</div>
            }
          </div>
        ))}
      </div>
      {room.mjPrompt && (
        <div class="prompt-box">
          <span class="prompt-label">AI Design Prompt</span>
          <p class="prompt-text">{room.mjPrompt}</p>
        </div>
      )}
      <a href={base} class="back-link">← Back to Collection</a>
    </div>
  </div>
</Base>
