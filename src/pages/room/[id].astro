---
import Base from '../../layouts/Base.astro';
import roomsData from '../../data/rooms.json';

export async function getStaticPaths() {
  return roomsData.map(room => ({
    params: { id: room.queueId },
    props: { room },
  }));
}

const { room } = Astro.props;
const base = import.meta.env.BASE_URL;
const localImage = `${base}rooms/${room.queueId}.jpg`;
---
<Base title={room.plateNum + ' ' + room.setName} ogImage={localImage}>
  <style is:global>
    .hero{display:grid;grid-template-columns:1fr 380px;height:calc(100vh - 52px);min-height:600px;max-height:900px;}
    @media(max-width:768px){.hero{grid-template-columns:1fr;height:auto;}}
    .hero-img{position:relative;overflow:hidden;background:#C8C4BC;}
    .hero-img img{width:100%;height:100%;object-fit:cover;transition:transform 8s ease;}
    .hero-img:hover img{transform:scale(1.02);}
    .hero-plate{position:absolute;bottom:var(--s4);left:var(--s4);font-family:var(--f-mono);font-size:10px;color:rgba(255,255,255,.6);letter-spacing:.1em;text-transform:uppercase;}
    .hero-panel{display:flex;flex-direction:column;justify-content:space-between;padding:var(--s6) var(--s5);background:var(--white);border-left:1px solid var(--rule);}
    .hero-eyebrow{font-family:var(--f-mono);font-size:10px;color:var(--ink-3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:var(--s3);}
    .hero-title{font-family:var(--f-serif);font-weight:400;font-size:clamp(22px,2.2vw,32px);line-height:1.1;letter-spacing:.1em;text-transform:uppercase;}
    .hero-meta{margin-top:var(--s5);}
    .hero-meta-block{display:flex;flex-direction:column;gap:var(--s3);}
    .hero-meta-label{font-family:var(--f-mono);font-size:8px;text-transform:uppercase;letter-spacing:.1em;color:var(--ink-3);margin-bottom:2px;}
    .hero-meta-value{font-family:var(--f-italic);font-style:italic;font-size:16px;color:var(--ink);line-height:1.2;}
    .section{padding-block:var(--s8);}
    .sec-eye{font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin-bottom:var(--s6);}
    .shop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1px;background:var(--rule);}
    .shop-card{background:var(--paper);padding:var(--s4);}
    .shop-img{aspect-ratio:1/1;background:var(--rule-2);margin-bottom:var(--s3);overflow:hidden;display:flex;align-items:center;justify-content:center;}
    .shop-img img{width:100%;height:100%;object-fit:cover;}
    .shop-cat{font-family:var(--f-mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:var(--s1);}
    .shop-name{font-size:13px;font-weight:500;margin-bottom:2px;line-height:1.3;}
    .shop-brand{font-family:var(--f-italic);font-style:italic;font-size:13px;color:var(--ink-2);margin-bottom:var(--s3);}
    .shop-btn{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--ink);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;transition:all .2s;}
    .shop-btn:hover{background:var(--ink);color:var(--white);}
    .shop-btn-soon{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--rule);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
    .prompt-box{background:var(--ink);padding:var(--s6);margin-top:var(--s7);}
    .prompt-label{font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:var(--s3);display:block;}
    .prompt-text{font-family:var(--f-mono);font-size:11px;line-height:1.8;color:rgba(255,255,255,.7);white-space:pre-wrap;}
    .back-link{display:inline-block;margin-top:var(--s7);font-family:var(--f-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
    .back-link:hover{color:var(--blue);}
  </style>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-img">
      <img src={localImage} alt={room.setName} onerror="this.style.opacity='0'" />
      <div class="hero-plate">{room.plateNum} — {room.setName}</div>
    </div>
    <div class="hero-panel">
      <div>
        <div class="hero-eyebrow">Featured Room · {room.plateNum}</div>
        <h1 class="hero-title">{room.setName}</h1>
        <div class="hero-meta">
          <div class="hero-meta-block">
            <div>
              <div class="hero-meta-label">Layout</div>
              <div class="hero-meta-value">{room.layoutType}</div>
            </div>
            <div>
              <div class="hero-meta-label">Collection</div>
              <div class="hero-meta-value">{room.setName}</div>
            </div>
            <div>
              <div class="hero-meta-label">Rating</div>
              <div class="hero-meta-value">{room.rating}</div>
            </div>
          </div>
        </div>
      </div>
      <a class="hero-cta" href="#shop">
        Shop the Room
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <!-- SHOP THE ROOM -->
  <div class="wrap" id="shop">
    <div class="section">
      <div class="sec-eye">Shop the Room</div>
      <div class="shop-grid">
        {room.furniture.filter(f => f.name).map(f => (
          <div class="shop-card">
            <div class="shop-img">
              {f.imageUrl
                ? <img src={f.imageUrl} alt={f.name} loading="lazy" />
                : <span style="font-size:28px;opacity:.2;">🪑</span>
              }
            </div>
            {f.category && <div class="shop-cat">{f.category}</div>}
            <div class="shop-name">{f.name}</div>
            {f.brand && <div class="shop-brand">{f.brand}</div>}
            {f.affiliateUrl
              ? <a href={f.affiliateUrl} target="_blank" rel="noopener noreferrer" class="shop-btn">Shop →</a>
              : <div class="shop-btn-soon">Coming Soon</div>
            }
          </div>
        ))}
      </div>

      {room.mjPrompt && (
        <div class="prompt-box">
          <span class="prompt-label">AI Design Prompt</span>
          <p class="prompt-text">{room.mjPrompt}</p>
        </div>
      )}

      <a href={base} class="back-link">← Back to Collection</a>
    </div>
  </div>
</Base>
