---
import Base from '../../layouts/Base.astro';
import roomsData from '../../data/rooms.json';

export async function getStaticPaths() {
  return roomsData.map(room => ({
    params: { id: room.queueId },
    props: { room },
  }));
}

const { room } = Astro.props;
const base = import.meta.env.BASE_URL;
const localImage = `${base}rooms/${room.queueId}.jpg`;
---
<Base title={room.plateNum + ' ' + room.setName} ogImage={localImage}>
  <style is:global>
    .room-shop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1px;background:var(--rule);}
    .room-shop-card{background:var(--white);padding:var(--s3);flex:none;}
    .room-shop-card:hover{border-color:var(--ink);}
    .room-shop-img{aspect-ratio:1/1;overflow:hidden;background:#E8E5E0;margin-bottom:var(--s2);display:flex;align-items:center;justify-content:center;}
    .room-shop-img img{width:100%;height:100%;object-fit:cover;}
    .room-shop-soon{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--rule);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
    .room-shop-btn{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--ink);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink);transition:all .2s;}
    .room-shop-btn:hover{background:var(--ink);color:var(--white);}
    .room-back{display:inline-block;margin-top:var(--s6);font-family:var(--f-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
    .room-back:hover{color:var(--blue);}
    .room-prompt{background:var(--ink);padding:var(--s6);margin-top:var(--s7);}
    .room-prompt-label{font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:var(--s3);display:block;}
    .room-prompt-text{font-family:var(--f-mono);font-size:11px;line-height:1.8;color:rgba(255,255,255,.7);white-space:pre-wrap;}
  </style>

  <section class="hero">
    <div class="hero-img">
      <img src={localImage} alt={room.setName} onerror="this.outerHTML='<div class=ph></div>'" />
      <div class="hero-plate">{room.plateNum} — {room.setName}</div>
    </div>
    <div class="hero-panel">
      <div>
        <div class="hero-eyebrow">Featured Room · {room.plateNum}</div>
        <h1 class="hero-title">{room.setName}</h1>
        <p class="hero-desc">A curated interior featuring selected designer pieces.</p>
        <div class="hero-meta">
          <div class="hero-meta-block">
            <div>
              <div class="hero-meta-label">Style</div>
              <div class="hero-meta-value">Japanese Modern</div>
            </div>
            <div>
              <div class="hero-meta-label">Collection</div>
              <div class="hero-meta-value">{room.setName}</div>
            </div>
            <div>
              <div class="hero-meta-label">Layout</div>
              <div class="hero-meta-value">{room.layoutType}</div>
            </div>
          </div>
        </div>
      </div>
      <a class="hero-cta" href="#shop">
        Shop the Room
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </section>

  <section class="section" id="shop">
    <div class="wrap">
      <div class="sec-eye">Shop the Room</div>
      <div class="room-shop-grid">
        {room.furniture.filter(f => f.name).map(f => (
          <div class="room-shop-card">
            <div class="room-shop-img">
              {f.imageUrl
                ? <img src={f.imageUrl} alt={f.name} loading="lazy" />
                : <span style="font-size:28px;opacity:.2;">🪑</span>
              }
            </div>
            {f.category && <div class="shop-cat">{f.category}</div>}
            <div class="shop-name">{f.name}</div>
            {f.brand && <div class="shop-brand">{f.brand}</div>}
            {f.affiliateUrl
              ? <a href={f.affiliateUrl} target="_blank" rel="noopener noreferrer" class="room-shop-btn">Shop →</a>
              : <div class="room-shop-soon">Coming Soon</div>
            }
          </div>
        ))}
      </div>
      {room.mjPrompt && (
        <div class="room-prompt">
          <span class="room-prompt-label">AI Design Prompt</span>
          <p class="room-prompt-text">{room.mjPrompt}</p>
        </div>
      )}
      <a href={base} class="room-back">← Back to Collection</a>
    </div>
  </section>

</Base>
