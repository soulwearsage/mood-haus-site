---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'The Mood Haus — Interior Design for Every Home', ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — The Mood Haus</title>
  <meta name="description" content={description}>
  {ogImage && <meta property="og:image" content={ogImage}>}
  <meta property="og:title" content={title + ' — The Mood Haus'}>
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Antonio:wght@400;500;700&family=Cormorant+Garamond:ital@1&family=Inter:wght@400;500&family=IBM+Plex+Mono&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --ivory: #FAFAF8;
      --charcoal: #111111;
      --white: #FFFFFF;
      --rule: #E0DDD8;
      --blue: #28AADB;
      --text2: #555;
      --text3: #999;
    }
    body { background: var(--ivory); color: var(--charcoal); font-family: 'Inter', sans-serif; }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <header style="border-bottom: 1px solid var(--rule); padding: 0 40px; height: 56px; display: flex; align-items: center; justify-content: space-between; background: var(--charcoal);">
    <a href={base} style="font-family: 'Antonio', sans-serif; font-size: 18px; letter-spacing: .12em; text-transform: uppercase; color: var(--white);">The Mood Haus</a>
    <nav style="display: flex; gap: 28px;">
      <a href={base} style="font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--rule);">Collection</a>
      <a href={base + 'about'} style="font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--rule);">About</a>
    </nav>
  </header>
  <slot />
  <footer style="border-top: 1px solid var(--rule); padding: 40px; text-align: center; font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: .08em; color: var(--text3); margin-top: 80px;">
    © 2026 The Mood Haus — Interior Design for Every Home
  </footer>
</body>
</html>
