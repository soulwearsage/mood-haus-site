---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'The Mood Haus — Interior Design for Every Home', ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — The Mood Haus</title>
  <meta name="description" content={description}>
  {ogImage && <meta property="og:image" content={ogImage}>}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Antonio:wght@400;500;700&family=Cormorant+Garamond:ital,wght@1,300;1,400&family=Inter:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
:root{--paper:#FAFAF8;--white:#FFFFFF;--ink:#111111;--ink-2:#444444;--ink-3:#888888;--rule:#E0DDD8;--blue:#28AADB;--rule-2:#F0EDE8;--f-logo:'Antonio',sans-serif;--f-serif:'Antonio',sans-serif;--f-italic:'Cormorant Garamond',serif;--f-sans:'Inter',sans-serif;--f-mono:'IBM Plex Mono',monospace;--s1:4px;--s2:8px;--s3:16px;--s4:24px;--s5:32px;--s6:48px;--s7:64px;--s8:96px;--s9:140px;}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{background:var(--paper);color:var(--ink);font-family:var(--f-sans);-webkit-font-smoothing:antialiased;line-height:1.5;}
img{display:block;max-width:100%;}
a{color:inherit;text-decoration:none;}
.wrap{max-width:1400px;margin-inline:auto;padding-inline:var(--s5);}
@media(max-width:600px){.wrap{padding-inline:var(--s3);}}
.nav{position:sticky;top:0;z-index:100;background:rgba(250,250,248,.94);backdrop-filter:blur(8px);border-bottom:1px solid var(--rule);}
.nav-inner{display:flex;align-items:center;justify-content:space-between;height:52px;}
.logo{font-family:var(--f-logo);font-size:18px;font-weight:300;letter-spacing:.05em;text-transform:uppercase;}
.nav-links{display:flex;gap:var(--s5);list-style:none;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);}
.nav-links a:hover{color:var(--blue);}
.nav-right{display:flex;gap:var(--s3);align-items:center;}
.nav-icon{width:16px;height:16px;opacity:.5;cursor:pointer;}
.nav-icon:hover{opacity:1;color:var(--blue);}
@media(max-width:900px){.nav-links{display:none;}}
.hero{display:grid;grid-template-columns:1fr 380px;height:calc(100vh - 52px);min-height:600px;max-height:900px;}
@media(max-width:768px){.hero{grid-template-columns:1fr;height:auto;}.hero-panel{display:flex;}}
.hero-img{position:relative;overflow:hidden;background:#C8C4BC;}
@media(max-width:768px) and (min-width:600px){.hero-img{aspect-ratio:16/9;}.hero-panel{padding:var(--s4);}.hero-desc{margin-top:var(--s2);}.hero-meta{margin-top:var(--s2);}.hero-cta{margin-top:var(--s4);}}
@media(max-width:600px){.hero-img{aspect-ratio:4/5;}.hero-panel{padding:var(--s3);}.hero-desc{margin-top:var(--s1);}.hero-meta{margin-top:var(--s2);}.hero-cta{margin-top:var(--s3);}}
.hero-img img{width:100%;height:100%;object-fit:cover;transition:transform 8s ease;}
.hero-img:hover img{transform:scale(1.02);}
.hero-plate{position:absolute;bottom:var(--s4);left:var(--s4);font-family:var(--f-mono);font-size:10px;color:rgba(255,255,255,.6);letter-spacing:.1em;text-transform:uppercase;}
.hero-panel{display:flex;flex-direction:column;justify-content:space-between;padding:var(--s6) var(--s5);background:var(--white);border-left:1px solid var(--rule);}
.hero-eyebrow{font-family:var(--f-mono);font-size:10px;color:var(--ink-3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:var(--s3);}
.hero-title{font-family:var(--f-serif);font-weight:400;font-style:normal;font-size:clamp(22px,2.2vw,32px);line-height:1.1;letter-spacing:.1em;text-transform:uppercase;}
.hero-desc{font-size:13px;color:var(--ink-2);margin-top:var(--s4);line-height:1.7;max-width:32ch;}
.hero-meta{margin-top:var(--s5);}
.hero-meta-block{display:flex;flex-direction:column;gap:var(--s3);}
.hero-meta-label{font-family:var(--f-mono);font-size:8px;text-transform:uppercase;letter-spacing:.1em;color:var(--ink-3);margin-bottom:2px;}
.hero-meta-value{font-family:var(--f-italic);font-style:italic;font-size:16px;color:var(--ink);line-height:1.2;}
.hero-cta{display:inline-flex;align-items:center;gap:6px;font-size:11px;letter-spacing:.06em;text-transform:uppercase;border-bottom:1px solid var(--ink);padding-bottom:2px;margin-top:var(--s6);width:fit-content;position:relative;overflow:hidden;transition:color .2s;color:var(--ink);}
.hero-cta::after{content:'';position:absolute;bottom:0;left:-100%;width:100%;height:1px;background:var(--blue);transition:left .3s ease;}
.hero-cta:hover::after{left:0;}
.hero-cta:hover{color:var(--blue);}
.hero-cta svg{transition:transform .2s;}
.hero-cta:hover svg{transform:translateX(3px);}
.section{padding-block:var(--s8);border-bottom:1px solid var(--rule);}
.sec-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:var(--s6);}
.sec-eye{font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);margin-bottom:var(--s2);}
.sec-title{font-family:var(--f-serif);font-weight:400;font-size:clamp(22px,2.2vw,32px);letter-spacing:.1em;text-transform:uppercase;}
.sec-link{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);border-bottom:1px solid var(--rule);padding-bottom:2px;white-space:nowrap;}
.sec-link:hover{color:var(--blue);border-color:var(--blue);}
.room-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--s4);}
@media(max-width:1100px){.room-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:600px){.room-grid{grid-template-columns:1fr;}}
.room-card{cursor:pointer;}
.room-card:hover .room-img img{transform:scale(1.03);}
.room-card:hover .room-title{color:var(--blue);}
.room-img{position:relative;aspect-ratio:4/5;overflow:hidden;background:#CCCAC4;margin-bottom:var(--s3);}
.room-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease;}
.room-pl{position:absolute;top:var(--s2);left:var(--s2);font-family:var(--f-mono);font-size:9px;color:rgba(255,255,255,.7);letter-spacing:.08em;background:rgba(0,0,0,.25);padding:2px 6px;}
.room-title{font-family:var(--f-serif);font-size:16px;font-style:normal;letter-spacing:.1em;text-transform:uppercase;margin-bottom:3px;}
.room-sub{font-size:12px;color:var(--ink-3);font-family:var(--f-italic);font-style:italic;}
.shop-card{background:var(--white);border:1px solid var(--rule);padding:var(--s3);cursor:pointer;}
.shop-card:hover{border-color:var(--ink);}
.shop-img{aspect-ratio:1/1;overflow:hidden;background:#E8E5E0;margin-bottom:var(--s2);display:flex;align-items:center;justify-content:center;}
.shop-img img{width:100%;height:100%;object-fit:cover;}
.shop-cat{font-family:var(--f-mono);font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);margin-bottom:3px;}
.shop-name{font-size:12px;font-weight:500;margin-bottom:2px;line-height:1.3;}
.shop-brand{font-size:11px;color:var(--ink-3);font-family:var(--f-italic);font-style:italic;margin-bottom:var(--s3);}
.shop-btn{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--ink);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;transition:all .2s;color:var(--ink);}
.shop-btn:hover{background:var(--ink);color:var(--white);}
.shop-soon{display:block;text-align:center;padding:6px var(--s3);border:1px solid var(--rule);font-family:var(--f-mono);font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
.shop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1px;background:var(--rule);}
.prompt-box{background:var(--ink);padding:var(--s6);margin-top:var(--s7);}
.prompt-label{font-family:var(--f-mono);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);margin-bottom:var(--s3);display:block;}
.prompt-text{font-family:var(--f-mono);font-size:11px;line-height:1.8;color:rgba(255,255,255,.7);white-space:pre-wrap;}
.back-link{display:inline-block;margin-top:var(--s6);font-family:var(--f-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-3);}
.back-link:hover{color:var(--blue);}
.footer{padding-block:var(--s7) var(--s4);border-top:1px solid var(--rule);margin-top:var(--s8);}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;font-size:10px;color:var(--ink-3);}
.footer-logo{font-family:var(--f-logo);font-size:16px;letter-spacing:.05em;text-transform:uppercase;}
.ph{width:100%;height:100%;background:linear-gradient(145deg,#D4D0C8 0%,#B8B4AA 50%,#9C9890 100%);}
  </style>
</head>
<body>
  <nav class="nav">
    <div class="wrap nav-inner">
      <a href={base} class="logo">The Mood Haus</a>
      <ul class="nav-links">
        <li><a href={base}>Collection</a></li>
        <li><a href={base + 'about/'}>About</a></li>
      </ul>
      <div class="nav-right">
        <a href="https://www.pinterest.com/themoodhaus" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12c0 4.2 2.6 7.8 6.3 9.3-.1-.8-.2-2 0-2.9.2-.8 1.3-5.4 1.3-5.4s-.3-.7-.3-1.6c0-1.5.9-2.7 2-2.7.9 0 1.4.7 1.4 1.6 0 1-.6 2.4-.9 3.7-.3 1.1.6 2 1.6 2 2 0 3.4-2.5 3.4-6 0-2.5-1.8-4.3-4.9-4.3-3.6 0-5.8 2.7-5.8 5.4 0 1 .4 2.1.9 2.7.1.1.1.2.1.3l-.4 1.5c-.1.2-.2.3-.4.2-1.5-.7-2.4-2.8-2.4-4.6 0-3.7 2.7-7.2 7.8-7.2 4.1 0 7.3 2.9 7.3 6.8 0 4.1-2.6 7.3-6.1 7.3-1.2 0-2.3-.6-2.7-1.4l-.7 2.8c-.3 1-1 2.3-1.4 3 .9.3 1.9.4 3 .4 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
        </a>
      </div>
    </div>
  </nav>
  <slot />
  <footer class="footer">
    <div class="wrap footer-bottom">
      <span class="footer-logo">The Mood Haus</span>
      <span>© 2026 Interior Design for Every Home</span>
    </div>
  </footer>
</body>
</html>
