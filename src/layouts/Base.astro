---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const { title, description = 'The Mood Haus — Interior Design for Every Home', ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — The Mood Haus</title>
  <meta name="description" content={description}>
  {ogImage && <meta property="og:image" content={ogImage}>}
  <meta property="og:title" content={title + ' — The Mood Haus'}>
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Antonio:wght@400;500;700&family=Cormorant+Garamond:ital,wght@1,300;1,400&family=Inter:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    :root{
      --paper:#FAFAF8;--ink:#111111;--ink-2:#444444;--ink-3:#888888;
      --white:#FFFFFF;--rule:#E0DDD8;--rule-2:#F0EDE8;--blue:#28AADB;
      --f-logo:'Antonio',sans-serif;--f-serif:'Antonio',sans-serif;
      --f-italic:'Cormorant Garamond',serif;--f-sans:'Inter',sans-serif;
      --f-mono:'IBM Plex Mono',monospace;
      --s1:4px;--s2:8px;--s3:16px;--s4:24px;--s5:32px;--s6:48px;--s7:64px;--s8:96px;
    }
    html{scroll-behavior:smooth;}
    body{background:var(--paper);color:var(--ink);font-family:var(--f-sans);-webkit-font-smoothing:antialiased;line-height:1.5;}
    img{display:block;max-width:100%;}
    a{color:inherit;text-decoration:none;}
    .wrap{max-width:1400px;margin-inline:auto;padding-inline:var(--s5);}
    @media(max-width:600px){.wrap{padding-inline:var(--s3);}}
    nav{position:sticky;top:0;z-index:100;background:rgba(250,250,248,.94);backdrop-filter:blur(8px);border-bottom:1px solid var(--rule);}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;height:52px;}
    .logo{font-family:var(--f-logo);font-size:18px;font-weight:300;letter-spacing:.05em;text-transform:uppercase;}
    .nav-links{display:flex;gap:var(--s5);list-style:none;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-3);}
    .nav-links a:hover{color:var(--blue);}
    footer{border-top:1px solid var(--rule);padding:var(--s7) var(--s5);margin-top:var(--s8);}
    .foot-inner{display:flex;align-items:center;justify-content:space-between;}
    .foot-logo{font-family:var(--f-logo);font-size:16px;letter-spacing:.05em;text-transform:uppercase;}
    .foot-copy{font-family:var(--f-mono);font-size:10px;color:var(--ink-3);letter-spacing:.08em;}
  </style>
</head>
<body>
  <nav>
    <div class="nav-inner wrap">
      <a href={base} class="logo">The Mood Haus</a>
      <ul class="nav-links">
        <li><a href={base}>Collection</a></li>
        <li><a href={base + 'about/'}>About</a></li>
      </ul>
    </div>
  </nav>
  <slot />
  <footer>
    <div class="foot-inner wrap">
      <span class="foot-logo">The Mood Haus</span>
      <span class="foot-copy">© 2026 Interior Design for Every Home</span>
    </div>
  </footer>
</body>
</html>
